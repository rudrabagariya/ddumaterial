---
import Layout from '../../layouts/Layout.astro';
import materials from '../../data/materials.json';

export function getStaticPaths() {
  const paths = [];
  materials.semesters.forEach(sem => {
    sem.subjects.forEach(sub => {
      sub.resources.forEach(res => {
        paths.push({
          params: { resourceId: res.id },
          props: { resource: res, subject: sub },
        });
      });
    });
  });
  return paths;
}

const { resource, subject } = Astro.props;
---

<Layout title={resource.title}>
  <div class="container" style="max-width: 1400px;">
    <div class="mb-4 flex justify-between items-center flex-wrap gap-4">
      <div>
        <a href={`/subject/${subject.id}`} class="btn btn-outline" style="padding: 0.5rem 1rem; font-size: 0.85rem; margin-bottom: 1rem;">
          &larr; Back to {subject.name}
        </a>
        <h1 class="h2 text-gradient" style="margin: 0;">{resource.title}</h1>
      </div>
      
      <div class="flex gap-4 items-center">
        <span style="color: var(--text-muted);">{resource.size}</span>
        <a href={resource.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary" download>
          Download Original File
        </a>
      </div>
    </div>

    <div class="pdf-container">
      <iframe 
        class="pdf-iframe" 
        src={`${resource.url}#toolbar=0`} 
        title={resource.title}
      >
        <p>Your browser does not support PDFs. <a href={resource.url}>Download the PDF</a>.</p>
      </iframe>
    </div>
  </div>
</Layout>
